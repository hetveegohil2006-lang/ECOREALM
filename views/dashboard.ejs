<%- include('partials/header') %>

<div class="scanline"></div>

<div class="hud-container">
  
  <!-- Cyber HUD Header -->
  <header class="hud-header" role="banner">
    <div class="hud-logo-area"
         onclick="switchTab('orbital'); if(typeof playClickSound==='function') playClickSound();"
         title="Return to Command Center"
         aria-label="EcoREALM — Return to Orbital Sector"
         role="button"
         tabindex="0"
         style="cursor:pointer; transition: filter 0.25s ease;"
         onmouseenter="this.style.filter='drop-shadow(0 0 10px rgba(0,240,255,0.5))'"
         onmouseleave="this.style.filter='none'"
         onkeydown="if(event.key==='Enter'){switchTab('orbital');}">
      <div class="hud-logo-icon" aria-hidden="true">
        <i class="fa-solid fa-satellite-dish"></i>
      </div>
      <h1 class="hud-logo-text">EcoREALM</h1>
      <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); border: 1px solid rgba(0,240,255,0.2); padding: 2px 6px; border-radius: 4px; margin-left: 10px;" aria-hidden="true">SECTOR_7_ACTIVE</span>
    </div>

    <!-- Ticker metrics of current session state -->
    <div class="hud-stats-ticker">
      <div class="ticker-item" title="Command Level">
        <i class="fa-solid fa-shield-halved glow-cyan"></i>
        <span>LVL:</span>
        <span class="ticker-val" id="level-val"><%= user.level %></span>
      </div>
      <div class="ticker-item coin" title="Energy Coins">
        <i class="fa-solid fa-coins glow-yellow"></i>
        <span>COINS:</span>
        <span class="ticker-val" id="coin-val"><%= user.coins %></span>
      </div>
      <div class="ticker-item" title="Carbon Offset Telemetry">
        <i class="fa-solid fa-cloud-arrow-down"></i>
        <span>CO2:</span>
        <span class="ticker-val" id="carbon-val"><%= user.carbonOffset.toFixed(1) %></span> kg
      </div>
      <div class="ticker-item" title="Water Conserved Telemetry">
        <i class="fa-solid fa-droplet glow-cyan"></i>
        <span>H2O:</span>
        <span class="ticker-val" id="water-val"><%= user.waterSaved.toFixed(0) %></span> L
      </div>
      <div class="ticker-item" title="Energy Conserved Telemetry">
        <i class="fa-solid fa-plug"></i>
        <span>ENG:</span>
        <span class="ticker-val" id="energy-val"><%= user.energyConserved.toFixed(1) %></span> kWh
      </div>
    </div>

    <!-- User stats details and Actions -->
    <div class="hud-user-profile">
      <div class="hud-user-avatar" style="<%= user.avatar ? `background-image: url('${user.avatar}'); background-size: cover; background-position: center;` : '' %>">
        <% if (!user.avatar) { %>
          <i class="fa-solid fa-user-shield" style="font-size: 0.8rem; color: var(--accent-cyan);"></i>
        <% } %>
      </div>
      <div style="text-align: right; display: flex; flex-direction: column;">
        <span class="hud-user-name" id="hud-username-val"><%= user.username %></span>
        <span class="hud-user-rank" id="rank-val"><%= user.rank %></span>
      </div>
      <a href="/logout" aria-label="Sign out of your account">
        <button class="btn-hud-logout" aria-label="Sign Out">
          <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i> Sign Out
        </button>
      </a>
    </div>
  </header>

  <!-- Side Navigation & Main terminal Viewport -->
  <div class="hud-grid">
    <aside class="hud-sidebar" role="navigation" aria-label="Dashboard navigation">
      <div class="hud-menu-group">
        <span class="hud-menu-header">Simulation Command</span>
        <button class="hud-tab-btn active" onclick="switchTab('orbital')" aria-label="Orbital Sector — 3D Island Simulator" aria-current="true">
          <i class="fa-solid fa-cubes" aria-hidden="true"></i> <span>Orbital Sector</span>
        </button>
        <button class="hud-tab-btn" onclick="switchTab('worldmap')" aria-label="Planetary Map — World View">
          <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i> <span>Planetary Map</span>
        </button>
        
        <span class="hud-menu-header" style="margin-top: 15px;">Operations Deck</span>
        <button class="hud-tab-btn" onclick="switchTab('challenges')" aria-label="Missions Deck — Daily Eco Challenges">
          <i class="fa-solid fa-list-check" aria-hidden="true"></i> <span>Missions Deck</span>
        </button>
        <button class="hud-tab-btn" onclick="switchTab('carbon')" aria-label="Carbon Diagnostic — Footprint Wizard">
          <i class="fa-solid fa-clipboard-question" aria-hidden="true"></i> <span>Carbon Diagnostic</span>
        </button>
        <button class="hud-tab-btn" onclick="switchTab('arcade')" aria-label="Cosmic Arcade — Mini Games">
          <i class="fa-solid fa-gamepad" aria-hidden="true"></i> <span>Cosmic Arcade</span>
        </button>

        <span class="hud-menu-header" style="margin-top: 15px;">Mainframe Network</span>
        <button class="hud-tab-btn" onclick="switchTab('community')" aria-label="Community Link — Social Feed">
          <i class="fa-solid fa-tower-broadcast" aria-hidden="true"></i> <span>Community Link</span>
        </button>
        <button class="hud-tab-btn" onclick="switchTab('profile')" aria-label="Command Tier — Your Profile">
          <i class="fa-solid fa-id-card-clip" aria-hidden="true"></i> <span>Command Tier</span>
        </button>
        <a href="/knowledge" style="text-decoration: none;" aria-label="Knowledge Center — Learn about climate">
          <button class="hud-tab-btn" style="width: 100%; text-align: left; display: flex; align-items: center; gap: 8px;" aria-label="Knowledge Center">
            <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i> <span>Knowledge Center</span>
          </button>
        </a>
      </div>

      <!-- Footer sound control inside sidebar -->
      <div class="hud-audio-control">
        <span class="audio-toggle-lbl" id="audio-label"><i class="fa-solid fa-volume-high" aria-hidden="true"></i> SYSTEM SOUNDS</span>
        <div class="audio-switch active" id="audio-toggle-switch" onclick="toggleAudioSystem()" role="switch" aria-checked="true" aria-labelledby="audio-label" tabindex="0" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleAudioSystem();}"></div>
      </div>
    </aside>

    <!-- Main Viewport screens container -->
    <main class="hud-main-frame" id="main-content" role="main" aria-label="Dashboard main content area">
      
      <!-- 1. ORBITAL VIEW (3D Simulator) -->
      <section class="hud-viewport-screen active" id="screen-orbital">
        <div class="orbital-wrapper">
          <div class="view-header">
            <div class="view-title-box">
              <span class="view-title-main">Restoration Sector 7</span>
              <span class="view-title-desc">Dynamic 3D Floating Ecosystem Simulation</span>
            </div>
            
            <div class="island-metrics" style="position: relative; top: 0; right: 0; display: flex; flex-direction: row; gap: 15px;">
              <div class="metric-pill water">
                <i class="fa-solid fa-droplet glow-cyan"></i> Water Cleanliness: <span id="water-pill-val"><%= user.island.waterCleanliness %></span>%
              </div>
              <div class="metric-pill meadow">
                <i class="fa-solid fa-seedling glow-green"></i> Meadow Health: <span id="meadow-pill-val"><%= user.island.meadowGreenness %></span>%
              </div>
            </div>
          </div>
          
          <div class="orbital-canvas-frame">
            <div class="orbital-hud-gridlines"></div>
            <div class="orbital-hud-overlay">
              <div class="orbital-hud-telemetry">> SCANNERS: ON</div>
              <div class="orbital-hud-telemetry">> ORBITAL RATE: 0.0015 R/s</div>
              <div class="orbital-hud-telemetry" id="3d-trees-counter">> BIOMASS CORES: <%= user.island.trees %> TREES</div>
              <div class="orbital-hud-telemetry" id="3d-solar-counter">> SOLAR ARRAY CONNECTIONS: <%= user.island.solarPanels %></div>
            </div>
            
            <canvas id="realm-canvas" aria-label="3D Floating Island Ecosystem Simulation" role="img"></canvas>
            
            <div class="canvas-controls-hint">
              <i class="fa-solid fa-arrows-spin"></i> Rotate: Click & Drag | Zoom: Scroll
            </div>
          </div>
          
          <!-- Bottom controls bar -->
          <div class="orbital-controls-bar">
            <span class="orbital-controls-title"><i class="fa-solid fa-circle-info"></i> Simulation Control Parameters</span>
            <div class="orbital-btn-switches">
              <button class="btn-switch-hud active" id="btn-toggle-scanlines" onclick="toggleScanlines()" aria-label="Toggle scanline overlay" role="switch" aria-checked="true">Scanlines: ON</button>
              <button class="btn-switch-hud" id="btn-toggle-lighting" onclick="toggleSimulationLighting()" aria-label="Toggle day and night lighting" role="switch" aria-checked="false">Day/Night: DAY</button>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. PLANETARY WORLD MAP VIEW -->
      <section class="hud-viewport-screen" id="screen-worldmap">
        <div class="view-header">
          <div class="view-title-box">
            <span class="view-title-main">Tactical Restoration Map</span>
            <span class="view-title-desc">Click active regions to inspect environmental telemetry</span>
          </div>
        </div>
        
        <div class="map-frame">
          <div class="orbital-hud-gridlines"></div>
          <div class="map-svg-container">
            <!-- Semi-abstract geographic SVG representing global regions -->
            <svg viewBox="0 0 1000 500" width="100%" height="100%">
              <!-- Outline grids -->
              <line x1="0" y1="250" x2="1000" y2="250" stroke="rgba(0,240,255,0.08)" stroke-dasharray="5,5" />
              <line x1="500" y1="0" x2="500" y2="500" stroke="rgba(0,240,255,0.08)" stroke-dasharray="5,5" />
              
              <!-- Industrial Restoration Zone (North America) -->
              <path class="map-region-node" d="M150 120 L280 120 L280 200 L180 200 Z" id="region-industrial" onclick="selectMapRegion('industrial')" role="button" tabindex="0" aria-label="Industrial Restoration Zone: North America" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('industrial');}" />
              
              <!-- Ocean Cleanup Coast (Atlantic/Pacific Coast) -->
              <path class="map-region-node" d="M300 240 L350 210 L380 280 L330 310 Z" id="region-ocean" onclick="selectMapRegion('ocean')" role="button" tabindex="0" aria-label="Ocean Cleanup Coast: Atlantic and Pacific Coast" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('ocean');}" />
              
              <!-- Forest Conservation Zone (Amazon basin) -->
              <path class="map-region-node" d="M220 280 L290 280 L310 380 L200 360 Z" id="region-forest" onclick="selectMapRegion('forest')" role="button" tabindex="0" aria-label="Forest Conservation Zone: Amazon Basin" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('forest');}" />
              
              <!-- Green Energy Zone (Europe/North Africa) -->
              <path class="map-region-node" d="M480 140 L580 120 L610 200 L510 220 Z" id="region-energy" onclick="selectMapRegion('energy')" role="button" tabindex="0" aria-label="Green Energy Zone: Europe and North Africa" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('energy');}" />
              
              <!-- Wildlife Sanctuary (African Savannah / Asia forests) -->
              <path class="map-region-node" d="M520 250 L620 240 L650 350 L560 360 Z" id="region-wildlife" onclick="selectMapRegion('wildlife')" role="button" tabindex="0" aria-label="Wildlife Sanctuary: African Savannah and Asia Forests" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('wildlife');}" />
              
              <!-- Net-Zero Future Hub (East Asia/Japan) -->
              <path class="map-region-node" d="M750 150 L860 140 L880 240 L780 260 Z" id="region-future" onclick="selectMapRegion('future')" role="button" tabindex="0" aria-label="Net-Zero Future Hub: East Asia and Japan" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault(); selectMapRegion('future');}" />
              
              <!-- SVG Labels -->
              <text x="210" y="160" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">INDUSTRIAL CO-1</text>
              <text x="250" y="330" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">FOREST CO-2</text>
              <text x="545" y="170" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">ENERGY CO-3</text>
              <text x="340" y="260" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">OCEAN CO-4</text>
              <text x="580" y="300" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">WILDLIFE CO-5</text>
              <text x="815" y="200" fill="#fff" font-family="var(--font-mono)" font-size="12" text-anchor="middle" pointer-events="none">NET-ZERO CO-6</text>
            </svg>
          </div>
          
          <!-- Interactive map slide-out panel -->
          <div class="map-overlay-intel" id="map-overlay-intel">
            <div class="intel-info-box">
              <span class="intel-name" id="intel-region-name">REGION NAME</span>
              <span class="intel-status" id="intel-region-status">STATUS</span>
            </div>
            
            <div style="font-size: 0.85rem; max-width: 400px; color: var(--text-cyan);" id="intel-region-desc">
              Select a sector node to run diagnostic analysis.
            </div>
            
            <div class="intel-progress-group">
              <span class="intel-progress-lbl">RESTORATION:</span>
              <div class="intel-progress-bar">
                <div class="intel-progress-fill" id="intel-region-fill"></div>
              </div>
              <span class="intel-progress-lbl" style="color: var(--accent-green);" id="intel-region-perc">0%</span>
            </div>
            
            <button class="intel-close-btn" onclick="closeMapRegion()"><i class="fa-solid fa-circle-xmark"></i></button>
          </div>
        </div>
      </section>

      <!-- 3. MISSIONS DECK VIEW -->
      <section class="hud-viewport-screen" id="screen-challenges">
        <div class="view-header">
          <div class="view-title-box">
            <span class="view-title-main">Tactical Missions</span>
            <span class="view-title-desc">Log real-world ecological actions to synchronize biomass coins & experience</span>
          </div>
        </div>
        
        <div class="challenges-grid">
          <% Object.keys(habits).forEach(function(key) { %>
            <div class="challenge-card">
              <div class="challenge-card-header">
                <span class="challenge-card-title"><%= habits[key].name %></span>
                <i class="fa-solid fa-circle-info" style="color: var(--accent-cyan); cursor: help;" title="Ecosystem effect: -<%= habits[key].carbon %> kg CO2, +<%= habits[key].water %> L water, +<%= habits[key].energy %> kWh energy saved"></i>
              </div>
              
              <div class="challenge-card-rewards">
                <div class="challenge-reward-tag xp">
                  <i class="fa-solid fa-bolt"></i> +<%= habits[key].xp %> XP
                </div>
                <div class="challenge-reward-tag coin">
                  <i class="fa-solid fa-coins"></i> +<%= habits[key].coins %> Coins
                </div>
              </div>
              
              <button class="btn-challenge-action btn-log" data-habit-id="<%= key %>">
                <i class="fa-solid fa-plus-circle"></i> Log Mission Action
              </button>
            </div>
          <% }); %>
        </div>
      </section>

      <!-- 4. CARBON DIAGNOSTIC VIEW -->
      <section class="hud-viewport-screen" id="screen-carbon">
        <div class="view-header">
          <div class="view-title-box">
            <span class="view-title-main">Carbon Briefing Assessment</span>
            <span class="view-title-desc">Conduct scanning analysis of personal consumption patterns</span>
          </div>
        </div>
        
        <div class="carbon-wizard-box glass-panel">
          <!-- Step 1: Transport -->
          <div class="carbon-step-card active" id="carbon-step-1">
            <span class="carbon-step-title">[DIAGNOSTIC 01/04] Transit Link Analysis</span>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Select your primary transportation method for weekly activities.</p>
            <div class="carbon-options-list">
              <button class="carbon-option-btn" onclick="selectCarbonOption(1, 'car', 4.5)">Single Occupant Fossil Fuel Car (-4.5 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(1, 'transit', 1.2)">Public Transit Link (-1.2 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(1, 'active', 0)">Active Commuting (Walk/Bike/EV) (0.0 Optimal)</button>
            </div>
          </div>
          
          <!-- Step 2: Food -->
          <div class="carbon-step-card" id="carbon-step-2">
            <span class="carbon-step-title">[DIAGNOSTIC 02/04] Dietary Energy Load</span>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Specify your regular weekly dietary profile.</p>
            <div class="carbon-options-list">
              <button class="carbon-option-btn" onclick="selectCarbonOption(2, 'meat', 3.8)">Heavy Meat and Dairy Reliance (-3.8 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(2, 'mixed', 1.8)">Mixed Diet / Occasional Meatless Days (-1.8 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(2, 'vegan', 0.4)">Plant-Based / Zero Livestock Consumption (-0.4 Optimal)</button>
            </div>
          </div>
          
          <!-- Step 3: Energy -->
          <div class="carbon-step-card" id="carbon-step-3">
            <span class="carbon-step-title">[DIAGNOSTIC 03/04] Household Energy Matrix</span>
            <p style="color: var(--text-muted); font-size: 0.9rem;">What is the active heating/electricity profile of your shelter?</p>
            <div class="carbon-options-list">
              <button class="carbon-option-btn" onclick="selectCarbonOption(3, 'coal', 5.0)">Standard Grid Electricity with Fossil Heating (-5.0 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(3, 'hybrid', 2.2)">Insulated Hybrid Grid / Heat-Pump Retrofit (-2.2 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(3, 'solar', 0.2)">Local Solar Panel Generation / Heat Recovery (-0.2 Optimal)</button>
            </div>
          </div>
          
          <!-- Step 4: Waste -->
          <div class="carbon-step-card" id="carbon-step-4">
            <span class="carbon-step-title">[DIAGNOSTIC 04/04] Material Disposal Loops</span>
            <p style="color: var(--text-muted); font-size: 0.9rem;">How does your command post process trash recycling?</p>
            <div class="carbon-options-list">
              <button class="carbon-option-btn" onclick="selectCarbonOption(4, 'landfill', 2.5)">Everything to Landfill / Minimal Sorting (-2.5 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(4, 'sorting', 0.9)">Standard Recycling Sort / Plastic Bottles (-0.9 Rating)</button>
              <button class="carbon-option-btn" onclick="selectCarbonOption(4, 'zero', 0.1)">Zero-Waste Loop / Composting (-0.1 Optimal)</button>
            </div>
          </div>

          <!-- Step 5: Scoring -->
          <div class="carbon-step-card" id="carbon-step-5">
            <span class="carbon-step-title">[DIAGNOSTIC COMPLETED] Mainframe Feedback</span>
            <div class="carbon-score-display" style="display: flex; flex-direction: column; gap: 20px; align-items: center; width: 100%;">
              <div style="display: flex; gap: 20px; align-items: center; justify-content: center; width: 100%; flex-wrap: wrap;">
                <div class="carbon-score-ring"><span id="carbon-final-score">15.8</span></div>
                <div style="text-align: left; max-width: 300px;">
                  <p style="font-weight: bold; color: var(--accent-cyan); font-family: var(--font-mono);" id="carbon-grade-label">DIAGNOSTIC: CRITICAL DEGRADATION</p>
                  <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin-top: 5px;">
                    Your estimated annual carbon score is <span id="carbon-score-text">15.8</span> metric tonnes. The global target is under 2.0 tonnes.
                  </p>
                </div>
              </div>

              <!-- Carbon Projections -->
              <div class="glass-panel" style="width: 100%; padding: 15px; text-align: left; box-sizing: border-box;">
                <span class="dossier-label-mini" style="margin-bottom: 10px; display: block;"><i class="fa-solid fa-chart-line"></i> Projected Emissions Projections</span>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 10px;">
                  <div style="background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(0,240,255,0.05);">
                    <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">DAILY</span>
                    <span style="font-family: var(--font-mono); font-size: 1rem; font-weight: bold; color: var(--accent-cyan);" id="proj-daily">0.0</span> <span style="font-size: 0.7rem; color: var(--text-muted);">kg</span>
                  </div>
                  <div style="background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(0,240,255,0.05);">
                    <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">WEEKLY</span>
                    <span style="font-family: var(--font-mono); font-size: 1rem; font-weight: bold; color: var(--accent-cyan);" id="proj-weekly">0.0</span> <span style="font-size: 0.7rem; color: var(--text-muted);">kg</span>
                  </div>
                  <div style="background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(0,240,255,0.05);">
                    <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">MONTHLY</span>
                    <span style="font-family: var(--font-mono); font-size: 1rem; font-weight: bold; color: var(--accent-cyan);" id="proj-monthly">0.0</span> <span style="font-size: 0.7rem; color: var(--text-muted);">kg</span>
                  </div>
                  <div style="background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border: 1px solid rgba(0,240,255,0.05);">
                    <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">YEARLY</span>
                    <span style="font-family: var(--font-mono); font-size: 1rem; font-weight: bold; color: var(--accent-cyan);" id="proj-yearly">0.0</span> <span style="font-size: 0.7rem; color: var(--text-muted);">kg</span>
                  </div>
                </div>
              </div>

              <!-- AI Recommendations -->
              <div class="glass-panel-green" style="width: 100%; padding: 15px; text-align: left; border-color: rgba(57,255,20,0.15) !important; box-sizing: border-box;">
                <span class="dossier-label-mini" style="color: var(--accent-green); margin-bottom: 10px; display: block;"><i class="fa-solid fa-robot"></i> Personal AI Recommendations</span>
                <div id="ai-recs-list" style="display: flex; flex-direction: column; gap: 8px; font-size: 0.82rem; color: var(--text-cyan);">
                  <!-- Populated dynamically via JS -->
                </div>
              </div>

              <button class="btn-cyber green-theme" style="padding: 10px 24px;" onclick="resetCarbonWizard()">
                <i class="fa-solid fa-arrows-rotate"></i> Recalibrate Core
              </button>
            </div>
          </div>

          <!-- Diagnostic Controls footer -->
          <div class="carbon-wizard-controls" id="carbon-controls">
            <button class="btn-switch-hud" onclick="slideCarbonStep(-1)"><i class="fa-solid fa-arrow-left"></i> Previous</button>
            <button class="btn-cyber" id="carbon-next-btn" onclick="slideCarbonStep(1)" style="padding: 6px 16px;">Next Step <i class="fa-solid fa-arrow-right"></i></button>
          </div>
        </div>
      </section>

      <!-- 5. COSMIC ARCADE VIEW -->
      <section class="hud-viewport-screen" id="screen-arcade">
        <div class="view-header">
          <div class="view-title-box">
            <span class="view-title-main">Simulation Arcade Hub</span>
            <span class="view-title-desc">Deploy training simulations to earn bonus energy coins</span>
          </div>
