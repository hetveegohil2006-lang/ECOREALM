<%- include('partials/header') %>

<style>
  .error-page-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #03050c;
    font-family: var(--font-mono, 'Orbitron', monospace);
    position: relative;
    overflow: hidden;
    padding: 40px 20px;
  }

  .error-page-container::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255, 50, 50, 0.01) 2px,
      rgba(255, 50, 50, 0.01) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .error-code {
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 900;
    font-family: 'Orbitron', monospace;
    background: linear-gradient(135deg, #ff4444, #ff8800, #ff4444);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    letter-spacing: -4px;
    position: relative;
    z-index: 2;
    animation: glitchRed 5s infinite;
  }

  @keyframes glitchRed {
    0%, 88%, 100% { transform: translate(0, 0) skew(0deg); filter: hue-rotate(0deg); }
    89%  { transform: translate(-4px, 2px) skew(-3deg); filter: hue-rotate(20deg); }
    90%  { transform: translate(4px, -2px) skew(2deg); filter: hue-rotate(-15deg); }
    91%  { transform: translate(0, 0) skew(0deg); filter: hue-rotate(0deg); }
    92%  { transform: translate(-2px, 3px) skew(1deg); filter: hue-rotate(30deg); }
    93%  { transform: translate(0, 0) skew(0deg); filter: hue-rotate(0deg); }
  }

  .error-badge {
    font-family: 'Orbitron', monospace;
    font-size: 0.72rem;
    letter-spacing: 4px;
    color: #ff4444;
    border: 1px solid rgba(255, 68, 68, 0.35);
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 24px;
    background: rgba(255, 68, 68, 0.07);
    z-index: 2;
    position: relative;
    animation: pulseDanger 1.8s ease-in-out infinite;
  }

  @keyframes pulseDanger {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(255,68,68,0.2); }
    50% { opacity: 0.65; box-shadow: 0 0 22px rgba(255,68,68,0.5); }
  }

  .error-title {
    font-size: 1.5rem;
    font-family: 'Orbitron', monospace;
    color: #fff;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
    z-index: 2;
    position: relative;
  }

  .error-desc {
    max-width: 500px;
    text-align: center;
    color: rgba(255, 150, 150, 0.8);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: 40px;
    z-index: 2;
    position: relative;
  }

  .error-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    z-index: 2;
    position: relative;
  }

  .btn-cyber {
    padding: 12px 28px;
    font-family: 'Orbitron', monospace;
    font-size: 0.78rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: 1px solid rgba(255, 68, 68, 0.4);
    background: rgba(255, 68, 68, 0.08);
    color: #ff6666;
    cursor: pointer;
    border-radius: 4px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s;
  }
  .btn-cyber:hover {
    background: rgba(255, 68, 68, 0.18);
    border-color: #ff4444;
    box-shadow: 0 0 18px rgba(255, 68, 68, 0.3);
    transform: translateY(-2px);
  }

  .btn-cyber.green-theme {
    border-color: rgba(57, 255, 20, 0.4);
    background: rgba(57, 255, 20, 0.08);
    color: #39ff14;
  }
  .btn-cyber.green-theme:hover {
    background: rgba(57, 255, 20, 0.18);
    border-color: #39ff14;
    box-shadow: 0 0 16px rgba(57, 255, 20, 0.3);
  }

  .error-terminal {
    margin-top: 48px;
    background: rgba(0,0,0,0.65);
    border: 1px solid rgba(255, 68, 68, 0.2);
    border-radius: 6px;
    padding: 16px 20px;
    max-width: 480px;
    width: 100%;
    font-size: 0.75rem;
    color: rgba(255,150,150,0.6);
    z-index: 2;
    position: relative;
  }

  .error-terminal-line { margin-bottom: 4px; }
  .error-terminal-line .prompt { color: #ff4444; }
  .error-terminal-line .out { color: rgba(255,255,255,0.35); }
  .error-terminal-line .err { color: #ff2222; }

  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,68,68,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,68,68,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .retry-btn {
    margin-top: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    border: none;
    background: none;
    font-family: 'Orbitron', monospace;
    letter-spacing: 1px;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .retry-btn:hover { color: #ff6666; }
</style>

<div class="scanline"></div>
<div class="grid-bg"></div>

<div class="error-page-container" role="main" aria-label="500 Internal Server Error Page">
  <div class="error-badge" role="alert" aria-live="assertive">🔴 CRITICAL SYSTEM FAULT</div>
  <div class="error-code" aria-hidden="true">500</div>
  <h1 class="error-title">Core Meltdown Detected</h1>
  <p class="error-desc">
    An unexpected fault occurred in the biosphere restoration core. Our systems have logged the
    incident and repair protocols have been dispatched. Please retry your operation or return to
    the Command Center.
  </p>

  <div class="error-actions">
    <a href="/" class="btn-cyber green-theme" aria-label="Return to Command Center Dashboard">
      <i class="fa-solid fa-satellite-dish" aria-hidden="true"></i> Command Center
    </a>
    <button class="btn-cyber" onclick="window.location.reload()" aria-label="Retry the page">
      <i class="fa-solid fa-rotate" aria-hidden="true"></i> Retry Operation
    </button>
    <a href="javascript:history.back()" class="btn-cyber" style="border-color:rgba(255,255,255,0.15);color:rgba(255,255,255,0.4);" aria-label="Go back to previous page">
      <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Go Back
    </a>
  </div>

  <div class="error-terminal" role="complementary" aria-label="System error log terminal">
    <div class="error-terminal-line"><span class="prompt">ECOREALM_OS $</span> <span>run_diagnostics --subsystem core</span></div>
    <div class="error-terminal-line"><span class="out">  &gt; Running systems integrity check...</span></div>
    <% if (typeof err !== 'undefined' && err && process.env.NODE_ENV !== 'production') { %>
    <div class="error-terminal-line"><span class="err">  FAULT [500]: <%= err.message || 'Unknown internal error' %></span></div>
    <% } else { %>
    <div class="error-terminal-line"><span class="err">  FAULT [500]: Unhandled exception in restoration core processor.</span></div>
    <% } %>
    <div class="error-terminal-line"><span class="out">  &gt; Incident logged. Dispatching repair bots.</span></div>
    <div class="error-terminal-line"><span class="out">  &gt; Status: RECOVERING...</span></div>
  </div>
</div>

<%- include('partials/footer') %>
