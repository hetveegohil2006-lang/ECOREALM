    <!-- HUD SIDE PANEL - RIGHT (Atmospheric Telemetry) -->
    <aside class="hud-panel right-panel glass-panel">
      <div class="panel-header">
        <i class="fa-solid fa-chart-pie"></i> Restoration Statistics
      </div>
      <div class="panel-body">
        <div class="telemetry-box success">
          <span class="label">LIVE CO₂ REDUCTION</span>
          <span class="value text-green">-3.28 T/MO</span>
          <span class="delta"><i class="fa-solid fa-circle-check"></i> MEETS PARITY GOAL</span>
        </div>

        <div class="telemetry-box success">
          <span class="label">BIODIVERSITY RATE</span>
          <span class="value text-green">+1.15%</span>
          <span class="delta"><i class="fa-solid fa-arrow-trend-up"></i> FLORA POPULATION INCR</span>
        </div>

        <div class="telemetry-box info">
          <span class="label">GLOBAL IMPACT SCORE</span>
          <span class="value text-cyan">4,284 TONS</span>
          <span class="delta"><i class="fa-solid fa-globe"></i> REGIONAL TARGET SECURED</span>
        </div>

        <div class="sensor-feed">
          <span class="sensor-header">ACTIVE CONSERVATION SHIELD</span>
          <div class="sensor-grid">
            <div class="sensor-dot green">1A</div>
            <div class="sensor-dot green">2B</div>
            <div class="sensor-dot green">3C</div>
            <div class="sensor-dot green">4D</div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <!-- Synth Audio Controller -->
  <script>
    let audioCtx = null;
    function getAudioContext() {
      if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      }
      return audioCtx;
    }

    function playSound(freq, type, duration, vol = 0.1) {
      try {
        const ctx = getAudioContext();
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, ctx.currentTime);
        gainNode.gain.setValueAtTime(vol, ctx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
        osc.connect(gainNode);
        gainNode.connect(ctx.destination);
        osc.start();
        osc.stop(ctx.currentTime + duration);
      } catch (e) { }
    }

    function playHoverSound() { playSound(600, 'sine', 0.08, 0.03); }
    function playClickSound() { playSound(400, 'triangle', 0.15, 0.08); }
    function playSuccessSound() {
      playSound(261.63, 'sawtooth', 0.2, 0.06); // C4
      setTimeout(() => playSound(329.63, 'sawtooth', 0.2, 0.06), 120); // E4
      setTimeout(() => playSound(392.00, 'sawtooth', 0.2, 0.06), 240); // G4
      setTimeout(() => playSound(523.25, 'sine', 0.5, 0.1), 360); // C5
    }

    function attachHoverSounds() {
      document.querySelectorAll('.btn-hud-action, .hud-input, .logo-link, .link-cyan').forEach(el => {
        if (!el.dataset.soundAttached) {
          el.addEventListener('mouseenter', playHoverSound);
          el.addEventListener('click', playClickSound);
          el.dataset.soundAttached = "true";
        }
      });
    }

    // Simulation Boot Loader (Enhanced)
    const bootMessages = [
      { text: "INCOMING SECURE MAIN COMMAND CORE DATA...", type: "info" },
      { text: "CALIBRATING HOLOGRAPHIC BIOMASS GRID COMPILERS...", type: "info" },
      { text: "DECRYPTING QUANTUM DEFENSE ENCRYPTIONS... 100% OK", type: "success" },
      { text: "ESTABLISHING ECO-CORES RESPONSE SIGNALS... RESPONSE DETECTED", type: "info" },
      { text: "SYNCHRONIZING SATELLITE TERRAFORM DATA CHANNELS...", type: "info" },
      { text: "WARP SECTORS 1-6 LOADED SUCCESSFULLY.", type: "success" },
      { text: "RESTORE-OS v3.2.0 READY. STANDING BY FOR GUARDIAN AUTHENTICATION...", type: "success" }
    ];

    window.addEventListener('DOMContentLoaded', () => {
      const errorPresent = <%= error ? "true" : "false" %>;
      if (errorPresent) {
        document.getElementById('boot-container').style.display = 'none';
        const landing = document.getElementById('landing-wrapper');
        landing.style.display = 'flex';
        landing.style.opacity = '1';
        attachHoverSounds();
        initThree();
        return;
      }

      const logsContainer = document.getElementById('boot-logs');
      const fill = document.getElementById('boot-fill');
      const perc = document.getElementById('boot-perc');
      const statusText = document.getElementById('boot-status-text');

      let msgIndex = 0;
      let progress = 0;

      function addLogLine() {
        if (msgIndex < bootMessages.length) {
          const msg = bootMessages[msgIndex];
          const line = document.createElement('div');
          line.className = `boot-log-line ${msg.type}`;
          line.innerHTML = `<span>></span> <span>${msg.text}</span>`;
          logsContainer.appendChild(line);
          logsContainer.scrollTop = logsContainer.scrollHeight;
          statusText.textContent = msg.text;

          playSound(350 + (msgIndex * 40), 'sine', 0.05, 0.02);
          msgIndex++;
          setTimeout(addLogLine, 200 + Math.random() * 150);
        }
      }

      function updateLoader() {
        progress += Math.floor(Math.random() * 4) + 1;
        if (progress > 100) progress = 100;

        fill.style.width = `${progress}%`;
        perc.textContent = `${progress}%`;

        if (progress < 100) {
          setTimeout(updateLoader, 20 + Math.random() * 15);
        } else {
          setTimeout(finishBoot, 400);
        }
      }

      addLogLine();
      updateLoader();

      function finishBoot() {
        // Play a short synth chime
        playSound(200, 'triangle', 0.5, 0.05);
        setTimeout(() => playSound(400, 'triangle', 0.4, 0.08), 150);

        gsap.to('#boot-container', {
          opacity: 0,
          duration: 0.6,
          onComplete: () => {
            document.getElementById('boot-container').style.display = 'none';
            const landing = document.getElementById('landing-wrapper');
            landing.style.display = 'flex';
            gsap.to(landing, { opacity: 1, duration: 0.6 });
            attachHoverSounds();
            initThree();
            if (typeof window.signalBootComplete === 'function') {
              window.signalBootComplete();
            }
          }
        });
      }
    });

    // Three.js Restored Planet Globe Setup
    let scene, camera, renderer, globe, particles;

    function initThree() {
      const container = document.getElementById('hologram-viewport');
      if (!container) return;

      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
      camera.position.z = 18;

      renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // Restored Planet Globe Geometry (Vibrant Green Wireframe)
      const geometry = new THREE.IcosahedronGeometry(5, 2);
      const material = new THREE.MeshBasicMaterial({
        color: 0x5CFFB3, // Neon Green
        wireframe: true,
        transparent: true,
        opacity: 0.45
      });
      globe = new THREE.Mesh(geometry, material);
      scene.add(globe);

      // Add Green Nodes/Restored Points at vertices
      const positions = geometry.attributes.position;
      const nodeGeo = new THREE.SphereGeometry(0.12, 8, 8);
      const nodeMat = new THREE.MeshBasicMaterial({ color: 0x53E8FF, transparent: true, opacity: 0.8 }); // Cyan nodes

      // Deploy nodes
      for (let i = 0; i < 12; i++) {
        const index = Math.floor(Math.random() * (positions.count));
        const x = positions.getX(index);
        const y = positions.getY(index);
        const z = positions.getZ(index);

        const node = new THREE.Mesh(nodeGeo, nodeMat);
        node.position.set(x, y, z);
        globe.add(node);
      }

      // Add Restored Flora Particle Cloud (Cyan & Green mix)
      const particleCount = 250;
      const particleGeo = new THREE.BufferGeometry();
      const particlePositions = new Float32Array(particleCount * 3);
      const colors = new Float32Array(particleCount * 3);

      for (let i = 0; i < particleCount * 3; i += 3) {
        const u = Math.random();
        const v = Math.random();
        const theta = u * 2.0 * Math.PI;
        const phi = Math.acos(2.0 * v - 1.0);
        const r = 5.3 + Math.random() * 2.5;

        particlePositions[i] = r * Math.sin(phi) * Math.cos(theta);
        particlePositions[i + 1] = r * Math.sin(phi) * Math.sin(theta);
        particlePositions[i + 2] = r * Math.cos(phi);

        // Randomly green or cyan colors
        if (Math.random() > 0.5) {
          colors[i] = 0.36;     // 5CFFB3 Green
          colors[i + 1] = 1.0;
          colors[i + 2] = 0.7;
        } else {
          colors[i] = 0.32;     // 53E8FF Cyan
          colors[i + 1] = 0.91;
          colors[i + 2] = 1.0;
        }
      }

      particleGeo.setAttribute('position', new THREE.BufferAttribute(particlePositions, 3));
      particleGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

      const particleMat = new THREE.PointsMaterial({
        size: 0.08,
        vertexColors: true,
        transparent: true,
        opacity: 0.8
      });

      particles = new THREE.Points(particleGeo, particleMat);
      scene.add(particles);

      // Animation Loop
      function animate() {
        requestAnimationFrame(animate);
        globe.rotation.y += 0.003;
        globe.rotation.x += 0.001;
        particles.rotation.y -= 0.0015;
        renderer.render(scene, camera);
      }
      animate();

      // Mouse movement rotation response
      document.addEventListener('mousemove', (e) => {
        const mouseX = (e.clientX / window.innerWidth) - 0.5;
        const mouseY = (e.clientY / window.innerHeight) - 0.5;
        gsap.to(globe.rotation, { y: mouseX * 2.5, x: mouseY * 2.5, duration: 2 });
      });

      window.addEventListener('resize', () => {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      });
    }

    function googleOAuth() {
      const modal = document.getElementById('oauth-modal');
      modal.style.display = 'flex';
      // Close on backdrop click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.style.display = 'none';
      }, { once: true });
    }

    function goToScan() {
      window.location.href = '/scan';
    }

    // Handle Form Submit
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;

      const errorBanner = document.getElementById('error-banner');
      const btn = document.getElementById('submit-btn');

      errorBanner.style.display = 'none';
      btn.disabled = true;
      btn.querySelector('.btn-text').innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> AUTHENTICATING DECRYPTION KEY...`;

      // Visual scan overlay animation on submit
      const scanLine = document.createElement('div');
      scanLine.className = 'scanner-scanline-beam';
      document.getElementById('login-form-card').appendChild(scanLine);
      gsap.to(scanLine, { top: '100%', duration: 1.2, ease: 'power2.inOut', onComplete: () => scanLine.remove() });

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || "Authentication code rejected.");
        }

        // Play success chime
        playSuccessSound();

        // Hydrate stats deck display
        document.getElementById('user-rank').textContent = (data.user.rank || 'Seed Guardian').toUpperCase();
        document.getElementById('user-level').textContent = data.user.level || 1;
        document.getElementById('user-coins').textContent = data.user.ecoPoints || 100;
        document.getElementById('user-impact').textContent = `${(data.user.carbonScore || 0).toFixed(1)} kg CO₂`;

        // Animate card swap (Form -> Stats Deck)
        gsap.to('#login-form-card', {
          opacity: 0,
          scale: 0.95,
          duration: 0.5,
          onComplete: () => {
            document.getElementById('login-form-card').style.display = 'none';

            const statsPanel = document.getElementById('success-stats-panel');
            statsPanel.style.display = 'block';
            gsap.to(statsPanel, {
              opacity: 1,
              scale: 1,
              duration: 0.6,
              ease: 'back.out(1.2)',
              onComplete: () => {
                // Pulse scanner beam on success panel
                gsap.fromTo('#scanner-line',
                  { top: '0%' },
                  { top: '100%', duration: 2.5, repeat: -1, ease: 'power1.inOut' }
                );
              }
            });
          }
        });

      } catch (err) {
        btn.disabled = false;
        btn.querySelector('.btn-text').innerHTML = `<i class="fa-solid fa-power-off"></i> Initialize Login`;
        document.getElementById('error-text').textContent = `AUTHENTICITY DEVIATION: ${err.message.toUpperCase()}`;
        errorBanner.style.display = 'block';
        playSound(180, 'sawtooth', 0.3, 0.08); // Error synth tone
      }
    });
    function navigateSpa(e, url) {
      e.preventDefault();
      window.history.pushState({}, '', url);
      
      if (url === '/register') {
        document.getElementById('login-form-card').style.display = 'none';
        document.getElementById('success-stats-panel').style.display = 'none';
        document.getElementById('register-form-card').style.display = 'block';
      } else {
        document.getElementById('register-form-card').style.display = 'none';
        document.getElementById('success-stats-panel').style.display = 'none';
        document.getElementById('login-form-card').style.display = 'block';
      }
    }

    document.getElementById('register-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const username = document.getElementById('reg-username').value;
      const email = document.getElementById('reg-email').value;
      const password = document.getElementById('reg-password').value;
      const confirmPassword = document.getElementById('reg-confirmPassword').value;

      const errorBanner = document.getElementById('register-error-banner');
      const errorText = document.getElementById('register-error-text');
      const fallbackBtn = document.getElementById('fallback-continue-btn');

      if (password !== confirmPassword) {
        errorText.textContent = "DECRYPTION KEYS DO NOT MATCH. RETRY.";
        errorBanner.style.display = 'block';
        fallbackBtn.style.display = 'none';
        return;
      }

      errorBanner.style.display = 'none';

      const btn = document.getElementById('reg-submit-btn');
      btn.disabled = true;
      btn.querySelector('.btn-text').innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> TRANSMITTING CREDENTIALS...`;

      try {
        const response = await fetch('/api/auth/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, email, password })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || "Mission authorization failed.");
        }

        window.location.href = '/diagnostic-scan';

      } catch (err) {
        btn.disabled = false;
        btn.querySelector('.btn-text').innerHTML = `<i class="fa-solid fa-rocket"></i> Create Guardian Account`;
        errorText.textContent = "Unable to initialize system. Continue manually.";
        errorBanner.style.display = 'block';
        fallbackBtn.style.display = 'inline-block';
      }
    });

    function fallbackRegistration() {
      window.location.href = '/diagnostic-scan';
    }
  </script>

