          <div class="deck-card">
            <span class="label">ECO POINTS</span>
            <span class="value text-green" id="user-coins">100</span>
          </div>
          <div class="deck-card">
            <span class="label">OFFSET IMPACT</span>
            <span class="value text-cyan" id="user-impact">0 kg CO₂</span>
          </div>
        </div>

        <div class="deck-status-bar">
          <span class="log">> SECTOR ACCESS AUTHORIZED...</span>
          <span class="log">> SYNCING DIAGNOSTIC SCAN INTERFACE...</span>
        </div>

        <button class="btn-hud-action primary-btn green-theme" style="margin-top: 15px;" onclick="goToScan()">
          <span class="btn-text">Initialize Diagnostic Scan <i class="fa-solid fa-circle-play"></i></span>
        </button>
