PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/ecorealm
JWT_SECRET=ecorealm_jwt_access_secret_key_12345_secure_and_long
JWT_REFRESH_SECRET=ecorealm_jwt_refresh_secret_key_12345_secure_and_long
JWT_EXPIRE=1h

# OpenAI API Coach
